# ============================
# AstroGuru Bot Configuration
# ============================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Bot username (without @)
BOT_USERNAME=AstroGeniusGuruBot

# Promo Telegram channel (create channel, add bot as admin with Post Messages)
# Get channel ID: forward a channel post to @userinfobot or @getidsbot
PROMO_CHANNEL_ID=-100xxxxxxxxxx
PROMO_CHANNEL_USERNAME=AstroGuruChannel
CHANNEL_POST_ENABLED=true

# Webhook URL (for production, e.g. https://yourdomain.com)
# Leave empty for local development (polling mode)
WEBHOOK_URL=

# Webhook secret token (random string for security)
WEBHOOK_SECRET=your_webhook_secret_here

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# SQLite database path
DATABASE_PATH=./data/astroguru.db
# Production (Railway volume): /app/data/astroguru.db

# Mini App URL (the public URL where your webapp is served)
MINI_APP_URL=https://astroguru-production.up.railway.app/app

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Subscription price in Telegram Stars (monthly)
SUBSCRIPTION_PRICE=99

# Subscription duration in days
SUBSCRIPTION_DAYS=30

# One-time natal chart price in Stars
NATAL_CHART_PRICE=99

# Admin accounts — lifetime premium (comma-separated Telegram IDs and usernames)
ADMIN_TELEGRAM_IDS=6004279903
ADMIN_USERNAMES=ADBusinessAnalyst

# Lifetime Premium (not admin) — comma-separated usernames without @
LIFETIME_PREMIUM_USERNAMES=maraJB007,reverendigel,A1010A
LIFETIME_PREMIUM_TELEGRAM_IDS=

# AI via OpenRouter (https://openrouter.ai) — OpenAI-compatible API
# Without key the bot uses template horoscopes
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemini-2.5-flash
OPENAI_APP_TITLE=AstroGuru Bot
OPENAI_HTTP_REFERER=https://astroguru-production.up.railway.app
